# Copie ce fichier en .env et adapte si besoin :
#   cp .env.example .env
#
# Le fichier .env n'est pas versionne (voir .gitignore).

# --- PostgreSQL ---
POSTGRES_DB=streamnews
POSTGRES_USER=streamnews
POSTGRES_PASSWORD=streamnews123
DATABASE_URL=postgresql://streamnews:streamnews123@localhost:5432/streamnews

# --- Redis (broker Celery) ---
REDIS_URL=redis://localhost:6379/0

# --- Services ---
WEB_URL=http://localhost:3000
ANALYZER_URL=http://localhost:8000

# --- Web (Node) ---
PORT=3000
NODE_ENV=development

# --- Role noeud (homelab multi-Pi) ---
# local all-in-one : all
# node6 data : data
# node7 app  : app
# autres Pi  : worker
STREAMNEWS_ROLE=all

# Perf crawl (pages en parallele, borne)
CRAWL_CONCURRENCY=3

# =============================================================================
# Exemple homelab node6 (data) + node7 (app) + workers
# =============================================================================
# Sur node7 / workers :
# DATABASE_URL=postgresql://streamnews:streamnews123@node6.lan:5432/streamnews
# REDIS_URL=redis://node6.lan:6379/0
# WEB_URL=http://node7.lan:3000
# ANALYZER_URL=http://127.0.0.1:8000
# STREAMNEWS_ROLE=app
# CELERY_CONCURRENCY=1
