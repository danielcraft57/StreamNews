# =============================================================================
# StreamNews - environnement (PROD / homelab)
# =============================================================================
# Copie :  cp .env.example .env
# Puis remplace CHANGE_ME (mot de passe Postgres, etc.).
#
# Mode local (SQLite + Redis distant) :
#   cp .env.local.example .env.local
#   bash scripts/dev.sh --local
#
# .env et .env.local ne sont PAS versionnes.

STREAMNEWS_ENV=production

# --- Postgres ---
POSTGRES_DB=streamnews
POSTGRES_USER=streamnews
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://streamnews:CHANGE_ME@localhost:5432/streamnews

# --- Redis (broker Celery) ---
# Homelab data node : redis://node6.lan:6379/0
REDIS_URL=redis://localhost:6379/0

# --- Services ---
WEB_URL=http://localhost:3000
ANALYZER_URL=http://localhost:8000

# --- Web (Node) ---
PORT=3000
NODE_ENV=production

# --- Role noeud ---
# all | data | app | worker
STREAMNEWS_ROLE=all

CRAWL_CONCURRENCY=3
# CELERY_CONCURRENCY=1

# --- Logs ---
# LOG_DIR=/opt/streamnews/logs
LOG_LEVEL=INFO

# =============================================================================
# Exemple homelab (app sur node7, data sur node6)
# =============================================================================
# STREAMNEWS_ENV=production
# STREAMNEWS_ROLE=app
# DATABASE_URL=postgresql://streamnews:CHANGE_ME@node6.lan:5432/streamnews
# REDIS_URL=redis://node6.lan:6379/0
# WEB_URL=http://node7.lan:3000
# ANALYZER_URL=http://127.0.0.1:8000
# CELERY_CONCURRENCY=1
