# StreamNews - config LOCALE (SQLite + Redis distant)
# Usage :
#   cp .env.local.example .env.local
#   bash scripts/dev.sh --local
#
# Ne pas committer .env.local (gitignore).
# Pas de mot de passe DB ici (SQLite fichier local).

STREAMNEWS_ENV=local
STREAMNEWS_ROLE=all

# SQLite (fichier sous data/ a la racine du repo, ignore par git)
DATABASE_URL=sqlite:///./data/streamnews.db

# Redis distant (ex: Pi node13) - adapte l'host si besoin
REDIS_URL=redis://node13.lan:6379/0

WEB_URL=http://localhost:3000
ANALYZER_URL=http://localhost:8000
PORT=3000
NODE_ENV=development

CRAWL_CONCURRENCY=3
CELERY_CONCURRENCY=2
LOG_LEVEL=INFO
