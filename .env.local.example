# StreamNews - config LOCALE (SQLite + Redis node14)
# Usage :
#   cp .env.local.example .env.local
#   bash scripts/init-db.sh --local
#   bash scripts/dev.sh --local
#
# Ne pas committer .env.local (gitignore).
# Pas de mot de passe DB ici (SQLite fichier local).

STREAMNEWS_ENV=local
STREAMNEWS_ROLE=all

# SQLite (fichier sous data/ a la racine du repo, ignore par git)
DATABASE_URL=sqlite:///./data/streamnews.db

# Redis sur node14 (broker Celery) - adapte l'host si besoin
REDIS_URL=redis://node14.lan:6379/0

WEB_URL=http://localhost:3000
ANALYZER_URL=http://localhost:8000
PORT=3000
NODE_ENV=development

CRAWL_CONCURRENCY=3
CELERY_CONCURRENCY=2
# Poll RSS via Celery beat (minutes, min 5)
FEED_REFRESH_MINUTES=15
LOG_LEVEL=INFO

# --- Reconnaissance faciale (OPTIONNEL, off par defaut) ---
# pip install -r analyzer/requirements-faces.txt
# FACE_DETECT_ENABLED=1
# FACE_DETECT_BACKEND=face_recognition
# # ou insightface (souvent plus simple sous Windows)
# FACE_DETECT_BACKEND=insightface
# FACE_DETECT_MAX_IMAGES=5
# FACE_DETECT_TIMEOUT=15
