[Unit]
Description=StreamNews Celery Worker
After=network.target postgresql.service redis-server.service streamnews-analyzer.service

[Service]
Type=simple
User=streamnews
Group=streamnews
WorkingDirectory=/opt/streamnews/analyzer
EnvironmentFile=/opt/streamnews/.env
Environment=PATH=/opt/streamnews/.venv/bin:/usr/bin
ExecStart=/opt/streamnews/.venv/bin/python -m celery -A celery_worker worker --loglevel=info --concurrency=2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
