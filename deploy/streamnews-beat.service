[Unit]
Description=StreamNews Celery Beat (brief quotidien)
After=network.target

[Service]
Type=simple
User=streamnews
Group=streamnews
WorkingDirectory=/opt/streamnews/analyzer
EnvironmentFile=/opt/streamnews/.env
Environment=PATH=/opt/streamnews/.venv/bin:/usr/bin
Environment=LOG_DIR=/opt/streamnews/logs
Environment=LOG_LEVEL=INFO
ExecStart=/opt/streamnews/.venv/bin/python -m celery -A celery_worker beat --loglevel=info
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
