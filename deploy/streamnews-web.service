[Unit]
Description=StreamNews Web (Node/Express)
After=network.target

[Service]
Type=simple
User=streamnews
Group=streamnews
WorkingDirectory=/opt/streamnews/web
EnvironmentFile=/opt/streamnews/.env
Environment=LOG_DIR=/opt/streamnews/logs
Environment=LOG_LEVEL=info
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
