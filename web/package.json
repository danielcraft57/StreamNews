{
  "name": "streamnews-web",
  "version": "0.5.1",
  "description": "Interface web pour StreamNews RSS Analyzer",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:material": "esbuild src/material-entry.js --bundle --format=esm --outfile=public/vendor/material.js --minify",
    "postinstall": "npm run build:material",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@material/web": "^2.5.0",
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "serve-static": "^1.15.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "keywords": [
    "rss",
    "analyzer",
    "streamnews"
  ],
  "author": "StreamNews Team",
  "license": "MIT"
}
